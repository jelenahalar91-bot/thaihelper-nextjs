# Capacitor — native build outputs we never commit
# (the native projects themselves are checked in for reproducibility,
#  only the build artefacts and IDE state are ignored)
android/.gradle/
android/build/
android/app/build/
android/.idea/
android/local.properties
ios/App/build/
ios/App/Pods/
ios/DerivedData/
ios/App/App.xcworkspace/xcuserdata/
ios/App/*.xcodeproj/xcuserdata/
*.xcuserstate
# Source assets for icon/splash generation — outputs land in
# android/ + ios/ via `npx capacitor-assets generate`
assets/
