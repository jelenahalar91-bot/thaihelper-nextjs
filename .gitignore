# dependencies
node_modules/

# next.js
.next/
out/

# misc
.DS_Store
*.pem
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# debug
npm-debug.log*

# claude
.claude/
.agents/
skills-lock.json
.vercel
.env*.local

# Capacitor — native build outputs we never commit
# (the native projects themselves are checked in for reproducibility,
#  only the build artefacts and IDE state are ignored)
android/.gradle/
android/build/
android/app/build/
android/.idea/
android/local.properties
ios/App/build/
ios/App/Pods/
ios/DerivedData/
ios/App/App.xcworkspace/xcuserdata/
ios/App/*.xcodeproj/xcuserdata/
*.xcuserstate
# Source assets for icon/splash generation — outputs land in
# android/ + ios/ via `npx capacitor-assets generate`
assets/

# Local-only operational files — contain real user data (emails, phone
# numbers, ref codes from helper_profiles) or live messaging logs that
# we never want pushed to GitHub. These are scratch files for outreach,
# tester recruitment, internal stats — not source code.
#
# Safety net: even if someone runs `git add .`, none of this ships.
play-store/*.csv
play-store/*.json
marketing/
scripts/outreach/
scripts/check-*.js
scripts/send-*.js
scripts/find-*.js
scripts/dedupe-*.js
scripts/list-*.js
check-messaging*.js
messaging-detailed-report.js
