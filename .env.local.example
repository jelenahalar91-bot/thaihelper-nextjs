# Google Apps Script URL for employer registrations
# 1. Create a Google Sheet with headers: Timestamp | First Name | Last Name | Email | City | Helper Types | Job Description | Source
# 2. Go to Extensions > Apps Script
# 3. Paste the code from scripts/employer-sheet.gs
# 4. Deploy as Web App (access: Anyone)
# 5. Copy the URL and paste it below

EMPLOYER_SHEET_URL=https://script.google.com/macros/s/YOUR-SCRIPT-ID/exec
