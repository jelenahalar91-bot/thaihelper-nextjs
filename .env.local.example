# ─── Resend Email Service ─────────────────────────────────────────────────────
# 1. Sign up at https://resend.com (free: 100 emails/day)
# 2. Go to API Keys → Create API Key
# 3. Paste the key below
# 4. Optional: verify your domain for custom "from" address

RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=ThaiHelper <onboarding@resend.dev>

# Email address that receives admin notifications (new helper / employer
# signups, abuse reports). Single address only.
ADMIN_EMAIL=you@example.com

# ─── JWT Secret ──────────────────────────────────────────────────────────────
# REQUIRED — at least 32 characters. The app refuses to boot without this.
# Sign session cookies AND unsubscribe tokens. Generate with:
#   openssl rand -hex 32

JWT_SECRET=your-secret-key-at-least-32-characters-long

# ─── Supabase (primary backend) ──────────────────────────────────────────────
# 1. Create a project at https://supabase.com
# 2. Run scripts/supabase-schema.sql + the per-feature migrations
#    (supabase-area-en.sql, supabase-availability-status.sql,
#     supabase-email-verified-at.sql, …) in the SQL editor
# 3. Create Storage buckets:
#      - "profile-photos" (public)
#      - "helper-documents" (private)
# 4. Copy your keys from Settings > API

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Google Translate API ────────────────────────────────────────────────────
# 1. Enable the Cloud Translation API in Google Cloud Console
# 2. Create an API key at APIs & Services > Credentials
# Used to romanise Thai-script names, translate bios, and translate the
# free-text area field at registration.

GOOGLE_TRANSLATE_API_KEY=your-google-translate-api-key

# ─── Google Analytics (optional) ─────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ─── Meta Pixel (Facebook Ads conversion tracking) ──────────────────────────
# 1. Go to Meta Business → Events Manager → Connect Data Sources
# 2. Choose Web → Meta Pixel → name it (e.g. "ThaiHelper Web")
# 3. Copy the 15-digit Pixel ID and paste below
# Fires automatically: PageView (every page), CompleteRegistration (helper
# signup), Lead (employer waitlist signup). Optimize new ad campaigns on
# "Conversions → CompleteRegistration" once data has accrued (~50 events).
NEXT_PUBLIC_FB_PIXEL_ID=1234567890123456

# ─── Cloudflare Turnstile (spam protection) ─────────────────────────────────
# 1. Go to https://dash.cloudflare.com → Turnstile → Add Widget
# 2. Choose "Managed" mode (invisible for most users)
# 3. Add your domain(s) to the widget
# 4. Copy the site key (public) and secret key (private)
# In production: required — verification fails closed if the secret is
# missing or Cloudflare is unreachable. In development, registration
# works without CAPTCHA for local testing.

NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA...
TURNSTILE_SECRET_KEY=0x4AAAAAAA...

# ─── Cron Secret (Vercel Cron Jobs) ─────────────────────────────────────────
# REQUIRED in production. Authenticates Vercel Cron requests to /api/cron/*.
# Vercel automatically attaches this as `Authorization: Bearer $CRON_SECRET`
# to its own cron requests when set in Project Settings > Environment
# Variables. Generate with:
#   openssl rand -hex 32

CRON_SECRET=any-long-random-string-please-set-in-production

# ─── Web Push Notifications (VAPID) ──────────────────────────────────────────
# Generate a fresh keypair with:
#   npx web-push generate-vapid-keys --json
# Public key is exposed to the browser (NEXT_PUBLIC_* prefix); private key
# stays server-side. VAPID_SUBJECT must be a mailto: or https: URL that
# identifies you as the sender — push services require this for abuse reports.

NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@thaihelper.app

# ─── LINE Messaging (helper / family notifications) ─────────────────────────
# 1. Create a LINE Official Account at https://developers.line.biz
# 2. Enable the Messaging API on that channel
# 3. Channel access token + secret from the channel settings page
# 4. OA basic ID (starts with @, e.g. @123abcde) — shown on the LINE Account
#    Manager dashboard. Embedded in the "add friend" QR / link.

LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
LINE_OA_BASIC_ID=@thaihelper

# ─── Launch Promo (free premium tier for early signups) ─────────────────────
# When PROMO_ACTIVE=true, every new employer signup is auto-granted the
# premium tier for PROMO_DAYS days. Turn off after the launch window.

PROMO_ACTIVE=false
PROMO_DAYS=90

# ─── Sentry Error Monitoring (optional) ─────────────────────────────────────
# 1. Create a project at https://sentry.io (free: 5k errors/month)
# 2. Copy the DSN from Settings > Projects > [your project] > Client Keys
# Only active in production (NODE_ENV=production).

NEXT_PUBLIC_SENTRY_DSN=https://xxxx@o0.ingest.sentry.io/0
