# ─── Google Sheets (Apps Script Web App URLs) ─────────────────────────────────
# 1. Create a Google Sheet with the required headers
# 2. Go to Extensions > Apps Script
# 3. Paste the code from scripts/employer-sheet.gs (or helper-sheet.gs)
# 4. Deploy as Web App (access: Anyone)
# 5. Copy the URL and paste it below

EMPLOYER_SHEET_URL=https://script.google.com/macros/s/YOUR-SCRIPT-ID/exec
HELPER_SHEET_URL=https://script.google.com/macros/s/YOUR-SCRIPT-ID/exec

# ─── Resend Email Service ─────────────────────────────────────────────────────
# 1. Sign up at https://resend.com (free: 100 emails/day)
# 2. Go to API Keys → Create API Key
# 3. Paste the key below
# 4. Optional: verify your domain for custom "from" address

RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=ThaiHelper <onboarding@resend.dev>

# ─── JWT Secret ──────────────────────────────────────────────────────────────
JWT_SECRET=your-secret-key-at-least-32-characters-long

# ─── Supabase (Messaging, Documents, Settings) ──────────────────────────────
# 1. Create a project at https://supabase.com
# 2. Run scripts/supabase-schema.sql in the SQL Editor
# 3. Create a Storage bucket named "helper-documents" (private)
# 4. Copy your keys from Settings > API

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Google Translate API ────────────────────────────────────────────────────
# 1. Enable the Cloud Translation API in Google Cloud Console
# 2. Create an API key at APIs & Services > Credentials

GOOGLE_TRANSLATE_API_KEY=your-google-translate-api-key

# ─── Google Analytics (optional) ─────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
